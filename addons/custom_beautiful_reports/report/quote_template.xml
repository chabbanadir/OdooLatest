<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_beautiful_report_saleorder_document" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="custom_beautiful_reports.beautiful_layout">
                <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                <t t-set="o" t-value="doc"/> <!-- ensure o is set for beautiful_layout compatibility if needed but layout uses doc fallback -->
                
                <div class="page">
                    <!-- Title -->
                    <div class="row align-items-center mb-4">
                        <div class="col-6">
                            <h2 class="beautiful-title">
                                <span t-if="doc.state not in ['draft','sent']">Order</span>
                                <span t-if="doc.state in ['draft','sent']">Quotation</span>
                                <br/>
                                <small style="font-size: 20px; color: #7f8c8d; font-weight: 500;" t-esc="doc.name"/>
                            </h2>
                        </div>
                    </div>

                    <!-- Details Box (Customer + Meta) -->
                    <div class="row beautiful-box mb-4">
                        <div class="col-6">
                            <div class="text-main mb-2">Customer / Invoicing Address:</div>
                            <h4 class="text-accent mb-1" style="font-weight: bold;"><t t-esc="doc.partner_id.name"/></h4>
                            <div t-if="doc.partner_id.street"><t t-esc="doc.partner_id.street"/></div>
                            <div t-if="doc.partner_id.city"><t t-esc="doc.partner_id.city"/></div>
                            <div t-if="doc.partner_id.country_id"><t t-esc="doc.partner_id.country_id.name"/></div>
                            <div t-if="doc.partner_id.vat" class="mt-2 text-main">
                                <t t-esc="doc.company_id.account_fiscal_country_id.vat_label or 'Tax ID'"/>: <t t-esc="doc.partner_id.vat"/>
                            </div>
                            
                            <div t-if="doc.partner_shipping_id and (doc.partner_shipping_id != doc.partner_id)" class="mt-3">
                                <div class="text-main mb-2">Shipping Address:</div>
                                <div style="font-weight: bold;"><t t-esc="doc.partner_shipping_id.name"/></div>
                                <div t-if="doc.partner_shipping_id.street"><t t-esc="doc.partner_shipping_id.street"/></div>
                                <div t-if="doc.partner_shipping_id.city"><t t-esc="doc.partner_shipping_id.city"/></div>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <div class="row mt-3" t-if="doc.date_order and doc.state not in ['draft','sent']">
                                <div class="col-6 text-main">Order Date:</div>
                                <div class="col-6"><t t-esc="doc.date_order" t-options='{"widget": "date"}'/></div>
                            </div>
                            <div class="row mt-3" t-if="doc.date_order and doc.state in ['draft','sent']">
                                <div class="col-6 text-main">Quotation Date:</div>
                                <div class="col-6"><t t-esc="doc.date_order" t-options='{"widget": "date"}'/></div>
                            </div>
                            <div class="row mt-2" t-if="doc.validity_date and doc.state in ['draft', 'sent']">
                                <div class="col-6 text-main">Expiration:</div>
                                <div class="col-6"><t t-esc="doc.validity_date"/></div>
                            </div>
                            <div class="row mt-2" t-if="doc.user_id.name">
                                <div class="col-6 text-main">Salesperson:</div>
                                <div class="col-6"><t t-esc="doc.user_id.name"/></div>
                            </div>
                        </div>
                    </div>

                    <!-- Lines -->
                    <table class="beautiful-table text-start">
                        <thead>
                            <tr>
                                <th name="th_description" class="text-start">Description</th>
                                <th name="th_quantity" class="text-end">Quantity</th>
                                <th name="th_priceunit" class="text-end">Unit Price</th>
                                <th name="th_discount" t-if="display_discount" class="text-end" groups="product.group_discount_per_so_line">Disc.%</th>
                                <th name="th_taxes" class="text-end">Taxes</th>
                                <th name="th_subtotal" class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="sale_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-foreach="doc.order_line" t-as="line">
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type">
                                        <td name="td_name"><span t-field="line.name"/></td>
                                        <td name="td_quantity" class="text-end">
                                            <span t-field="line.product_uom_qty"/>
                                            <span t-field="line.product_uom"/>
                                        </td>
                                        <td name="td_priceunit" class="text-end">
                                            <span t-field="line.price_unit"/>
                                        </td>
                                        <td t-if="display_discount" class="text-end" groups="product.group_discount_per_so_line">
                                            <span t-field="line.discount"/>
                                        </td>
                                        <td name="td_taxes" class="text-end">
                                            <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_id))"/>
                                        </td>
                                        <td name="td_subtotal" class="text-end o_price_total">
                                            <span t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Totals -->
                    <div class="row">
                        <div class="col-7">
                            <p t-field="doc.note" style="color: #7f8c8d; font-size: 13px; margin-top: 20px;"/>
                        </div>
                        <div class="col-5">
                            <table class="totals-table">
                                <t t-set="tax_totals" t-value="doc.tax_totals"/>
                                
                                <tr class="total-row-minor">
                                    <td>Subtotal</td>
                                    <td><span t-esc="tax_totals['formatted_amount_untaxed']"/></td>
                                </tr>
                                
                                <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                    <t t-set="subtotal_to_show" t-value="subtotal['name']"/>
                                    <t t-foreach="tax_totals['groups_by_subtotal'][subtotal_to_show]" t-as="amount_by_group">
                                        <tr>
                                            <t t-if="len(tax_totals['groups_by_subtotal'][subtotal_to_show]) > 1 or (tax_totals['amount_untaxed'] != amount_by_group['tax_group_base_amount'])">
                                                <td>
                                                    <span t-esc="amount_by_group['tax_group_name']"/>
                                                    <span class="text-nowrap"> on
                                                        <t t-esc="amount_by_group['formatted_tax_group_base_amount']"/>
                                                    </span>
                                                </td>
                                                <td><span class="text-nowrap" t-esc="amount_by_group['formatted_tax_group_amount']"/></td>
                                            </t>
                                            <t t-else="">
                                                <td><span t-esc="amount_by_group['tax_group_name']"/></td>
                                                <td><span class="text-nowrap" t-esc="amount_by_group['formatted_tax_group_amount']"/></td>
                                            </t>
                                        </tr>
                                    </t>
                                </t>

                                <tr class="total-row">
                                    <td>Total</td>
                                    <td><span t-esc="tax_totals['formatted_amount_total']"/></td>
                                </tr>
                            </table>
                            
                            <div t-if="doc.payment_term_id" class="text-end mt-3" style="font-size: 13px;">
                                <span class="font-weight-bold">Payment Terms: </span><span t-field="doc.payment_term_id.note"/>
                            </div>
                        </div>
                    </div>
                    
                    <div t-if="doc.signature" class="mt-4" name="signature">
                        <div class="offset-8 text-center">
                            <strong>Signature</strong>
                        </div>
                        <div class="offset-8 text-center">
                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 4cm; max-width: 8cm;" alt="Signature"/>
                        </div>
                        <div class="offset-8 text-center">
                            <p t-field="doc.signed_by"/>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
