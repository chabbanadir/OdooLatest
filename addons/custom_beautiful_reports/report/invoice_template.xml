<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_beautiful_report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="custom_beautiful_reports.beautiful_layout">
                <t t-set="o" t-value="o.with_context(lang=lang)" />
                
                <div class="page">
                    <!-- Title -->
                    <div class="row align-items-center mb-4">
                        <div class="col-6">
                            <h2 class="beautiful-title">
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'posted'">Invoice</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'draft'">Draft Invoice</span>
                                <span t-if="o.move_type == 'out_invoice' and o.state == 'cancel'">Cancelled Invoice</span>
                                <span t-if="o.move_type == 'out_refund'">Credit Note</span>
                                <span t-if="o.move_type == 'in_refund'">Vendor Credit Note</span>
                                <span t-if="o.move_type == 'in_invoice'">Vendor Bill</span>
                                <br/>
                                <small style="font-size: 20px; color: #7f8c8d; font-weight: 500;" t-if="o.name != '/'" t-field="o.name"/>
                            </h2>
                        </div>
                    </div>

                    <!-- Details Box (Customer + Meta) -->
                    <div class="row beautiful-box mb-4">
                        <div class="col-6">
                            <div class="text-main mb-2">Customer Details:</div>
                            <h4 class="text-accent mb-1" style="font-weight: bold;"><t t-esc="o.partner_id.name"/></h4>
                            <div t-if="o.partner_id.street"><t t-esc="o.partner_id.street"/></div>
                            <div t-if="o.partner_id.city"><t t-esc="o.partner_id.city"/></div>
                            <div t-if="o.partner_id.country_id"><t t-esc="o.partner_id.country_id.name"/></div>
                            <div t-if="o.partner_id.vat" class="mt-2 text-main">
                                <t t-esc="o.company_id.account_fiscal_country_id.vat_label or 'Tax ID'"/>: <t t-esc="o.partner_id.vat"/>
                            </div>
                        </div>
                        <div class="col-6 text-end">
                            <div class="row mt-3">
                                <div class="col-6 text-main">Date:</div>
                                <div class="col-6"><t t-esc="o.invoice_date"/></div>
                            </div>
                            <div class="row mt-2" t-if="o.invoice_date_due and o.move_type == 'out_invoice' and o.state == 'posted'">
                                <div class="col-6 text-main">Due Date:</div>
                                <div class="col-6"><t t-esc="o.invoice_date_due"/></div>
                            </div>
                            <div class="row mt-2" t-if="o.invoice_origin">
                                <div class="col-6 text-main">Source:</div>
                                <div class="col-6"><t t-esc="o.invoice_origin"/></div>
                            </div>
                            <div class="row mt-2" t-if="o.ref">
                                <div class="col-6 text-main">Reference:</div>
                                <div class="col-6"><t t-esc="o.ref"/></div>
                            </div>
                        </div>
                    </div>

                    <!-- Lines -->
                    <table class="beautiful-table text-start">
                        <thead>
                            <tr>
                                <th name="th_description" class="text-start">Description</th>
                                <th name="th_quantity" class="text-end">Quantity</th>
                                <th name="th_priceunit" class="text-end">Unit Price</th>
                                <th name="th_discount" t-if="display_discount" class="text-end">Disc.%</th>
                                <th name="th_taxes" class="text-end">Taxes</th>
                                <th name="th_subtotal" class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="invoice_tbody">
                            <t t-set="current_subtotal" t-value="0"/>
                            <t t-foreach="o.invoice_line_ids.sorted(key=lambda l: (-l.sequence, l.date, l.move_name, -l.id), reverse=True)" t-as="line">
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                <t t-set="current_subtotal" t-value="current_subtotal + line.price_total" groups="account.group_show_line_subtotals_tax_included"/>

                                <tr t-att-class="'bg-200 font-weight-bold o_line_section' if line.display_type == 'line_section' else 'font-italic o_line_note' if line.display_type == 'line_note' else ''">
                                    <t t-if="not line.display_type" name="account_invoice_line_accountable">
                                        <td name="account_invoice_line_name"><span t-field="line.name" t-options="{'widget': 'text'}"/></td>
                                        <td class="text-end">
                                            <span t-field="line.quantity"/>
                                            <span t-field="line.product_uom_id" groups="uom.group_uom"/>
                                        </td>
                                        <td class="text-end">
                                            <span class="text-nowrap" t-field="line.price_unit"/>
                                        </td>
                                        <td t-if="display_discount" class="text-end">
                                            <span class="text-nowrap" t-field="line.discount"/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="', '.join(map(lambda x: (x.description or x.name), line.tax_ids))" id="line_tax_ids"/>
                                        </td>
                                        <td class="text-end o_price_total">
                                            <span class="text-nowrap" t-field="line.price_subtotal" groups="account.group_show_line_subtotals_tax_excluded"/>
                                            <span class="text-nowrap" t-field="line.price_total" groups="account.group_show_line_subtotals_tax_included"/>
                                        </td>
                                    </t>
                                    <t t-if="line.display_type == 'line_section'">
                                        <td colspan="99">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                        <t t-set="current_section" t-value="line"/>
                                        <t t-set="current_subtotal" t-value="0"/>
                                    </t>
                                    <t t-if="line.display_type == 'line_note'">
                                        <td colspan="99">
                                            <span t-field="line.name" t-options="{'widget': 'text'}"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Totals -->
                    <div class="row">
                        <div class="col-7">
                            <p t-if="o.narration" name="comment" style="color: #7f8c8d; font-size: 13px; margin-top: 20px;">
                                <t t-esc="o.narration"/>
                            </p>
                        </div>
                        <div class="col-5">
                            <table class="totals-table">
                                <t t-set="tax_totals" t-value="o.tax_totals"/>
                                
                                <tr class="total-row-minor">
                                    <td>Subtotal</td>
                                    <td><span t-esc="tax_totals['formatted_amount_untaxed']"/></td>
                                </tr>
                                
                                <t t-foreach="tax_totals['subtotals']" t-as="subtotal">
                                    <t t-set="subtotal_to_show" t-value="subtotal['name']"/>
                                    <t t-foreach="tax_totals['groups_by_subtotal'][subtotal_to_show]" t-as="amount_by_group">
                                        <tr>
                                            <t t-if="len(tax_totals['groups_by_subtotal'][subtotal_to_show]) > 1 or (tax_totals['amount_untaxed'] != amount_by_group['tax_group_base_amount'])">
                                                <td>
                                                    <span t-esc="amount_by_group['tax_group_name']"/>
                                                    <span class="text-nowrap"> on
                                                        <t t-esc="amount_by_group['formatted_tax_group_base_amount']"/>
                                                    </span>
                                                </td>
                                                <td><span class="text-nowrap" t-esc="amount_by_group['formatted_tax_group_amount']"/></td>
                                            </t>
                                            <t t-else="">
                                                <td><span t-esc="amount_by_group['tax_group_name']"/></td>
                                                <td><span class="text-nowrap" t-esc="amount_by_group['formatted_tax_group_amount']"/></td>
                                            </t>
                                        </tr>
                                    </t>
                                </t>

                                <tr class="total-row">
                                    <td>Total</td>
                                    <td><span t-esc="tax_totals['formatted_amount_total']"/></td>
                                </tr>
                            </table>
                            
                            <div t-if="o.invoice_payment_term_id" class="text-end mt-3" style="font-size: 13px;">
                                <span class="font-weight-bold">Payment Terms: </span><span t-field="o.invoice_payment_term_id.note"/>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </xpath>
    </template>
</odoo>
